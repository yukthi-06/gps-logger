<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_settings.xml — Options screen layout
    Matches the navy / red colour palette of the main screen.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F5">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#0F3460"
        app:titleTextColor="@android:color/white"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ── Section header ─────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_logging"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:textColor="#888EAB"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <!-- ── Logging Frequency card ──────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Card title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_frequency"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="4dp" />

                <!-- Card subtitle -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/desc_frequency"
                    android:textSize="13sp"
                    android:textColor="#888EAB"
                    android:layout_marginBottom="20dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="16dp"
                    android:background="#EAEDF2" />

                <!-- Radio options -->
                <RadioGroup
                    android:id="@+id/rgFrequency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rb1s"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/freq_1s"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"
                        android:buttonTint="#0F3460"
                        android:gravity="center_vertical" />

                    <RadioButton
                        android:id="@+id/rb2s"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/freq_2s"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"
                        android:buttonTint="#0F3460"
                        android:gravity="center_vertical" />

                    <RadioButton
                        android:id="@+id/rb3s"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/freq_3s"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"
                        android:buttonTint="#0F3460"
                        android:gravity="center_vertical" />

                    <RadioButton
                        android:id="@+id/rb5s"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/freq_5s"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"
                        android:buttonTint="#0F3460"
                        android:gravity="center_vertical" />

                    <RadioButton
                        android:id="@+id/rb10s"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/freq_10s"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"
                        android:buttonTint="#0F3460"
                        android:gravity="center_vertical" />

                    <RadioButton
                        android:id="@+id/rb30s"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/freq_30s"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"
                        android:buttonTint="#0F3460"
                        android:gravity="center_vertical" />

                    <RadioButton
                        android:id="@+id/rb1m"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/freq_1m"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"
                        android:buttonTint="#0F3460"
                        android:gravity="center_vertical" />

                    <RadioButton
                        android:id="@+id/rb5m"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/freq_5m"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"
                        android:buttonTint="#0F3460"
                        android:gravity="center_vertical" />

                </RadioGroup>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp"
                    android:background="#EAEDF2" />

                <!-- Live summary -->
                <TextView
                    android:id="@+id/tvIntervalPreview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GPS fix logged: every 5 seconds"
                    android:textSize="13sp"
                    android:textColor="#0F3460"
                    android:textStyle="italic"
                    android:gravity="center" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Export Formats card ─────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_formats"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:textColor="#888EAB"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- JSON Checkbox -->
                <CheckBox
                    android:id="@+id/cbJson"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/format_json"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:buttonTint="#0F3460" />

                <!-- GPX Checkbox -->
                <CheckBox
                    android:id="@+id/cbGpx"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/format_gpx"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:buttonTint="#0F3460" />

                <!-- KML Checkbox -->
                <CheckBox
                    android:id="@+id/cbKml"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/format_kml"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:buttonTint="#0F3460" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Map Settings card ───────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_map"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:textColor="#888EAB"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_map_style_url"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="4dp" />

                <!-- Description -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/desc_map_style_url"
                    android:textSize="13sp"
                    android:textColor="#888EAB"
                    android:layout_marginBottom="16dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="16dp"
                    android:background="#EAEDF2" />

                <!-- URL Input EditText -->
                <EditText
                    android:id="@+id/etMapStyleUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:inputType="textUri"
                    android:hint="https://example.com/style.json"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:padding="12dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Cache Settings card ─────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OFFLINE STORAGE"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:textColor="#888EAB"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear Offline Map Cache"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="4dp" />

                <!-- Description -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Deletes all downloaded offline map regions to free up storage space."
                    android:textSize="13sp"
                    android:textColor="#888EAB"
                    android:layout_marginBottom="16dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="16dp"
                    android:background="#EAEDF2" />

                <!-- Delete Button -->
                <Button
                    android:id="@+id/btnClearCache"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Clear Offline Maps"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#D32F2F"
                    android:textAllCaps="false"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
    </ScrollView>
</LinearLayout>
